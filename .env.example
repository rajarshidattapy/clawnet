# ClawNet environment — copy to .env and fill in. Every key is optional:
# with none set, the policy engine, sandbox, evidence memory, and decision log
# all still work fully offline.

# ── AI explanations ───────────────────────────────────────────────────────────
# Enables the ClawNet agent's plain-English verdict explanations (GPT-4o-mini).
# The deterministic verdicts work without it.
OPENAI_API_KEY=

# ── Telegram alerts + approvals ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Route high-risk sandbox/network approvals to Telegram (1 = on, 0 = off).
CLAWNET_TELEGRAM_APPROVAL=0
# Local mock transport for Telegram, useful for testing without a real bot (1 = on).
TELEGRAM_MOCK_ENABLED=0

# ── Threat intelligence (core/web_search.py) ──────────────────────────────────
# Firecrawl free-tier key — enables crawling public advisories (CISA, NVD, …).
FIRECRAWL_API_KEY=
# Seconds between background threat-intel refreshes (default 21600 = 6h).
THREAT_INTEL_INTERVAL_SECONDS=21600
# Local crawl cache path and TTL (defaults: ~/.clawnet/threat_cache.json, 6h).
CLAWNET_THREAT_CACHE_PATH=
CLAWNET_THREAT_CACHE_TTL_SECONDS=21600

# ── Supermemory Local — semantic evidence/threat search ───────────────────────
# Run the server with: bash scripts/supermemory-local.sh  (prints the sm_ key).
# Without it, the JSONL evidence store remains the source of truth.
SUPERMEMORY_API_URL=http://localhost:6767

# ── Sandbox ───────────────────────────────────────────────────────────────────
# Where approved sandbox projects are promoted (default ~/clawnet-workspace).
CLAWNET_HOST_WORKSPACE=

# ── Testing (internal) ────────────────────────────────────────────────────────
# Deterministic record/replay of the agent's model calls: off | record | replay.
CLAWNET_REPLAY=off
